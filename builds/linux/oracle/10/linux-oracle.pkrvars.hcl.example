/*
    DESCRIPTION:
    Oracle Linux 10 build variables.
    Packer Plugin for VMware vSphere: 'vsphere-iso' builder.
*/

// Guest Operating System Metadata
vm_guest_os_name    = "oracle"
vm_guest_os_version = "10.1"

// Virtual Machine Guest Operating System Setting
vm_guest_os_type = "other6xLinux64Guest"

// Virtual Machine Hardware Settings
vm_firmware = "efi-secure"

// Removable Media Settings
iso_datastore_path       = "iso/linux/oracle-linux/10/amd64"
iso_content_library_item = "OracleLinux-R10-U1-x86_64-dvd"
iso_file                  = "OracleLinux-R10-U1-x86_64-dvd.iso"

